# MongoDB connection string — free M0 tier at mongodb.com/atlas
MONGODB_URI=mongodb://localhost:27017/weatherwise

# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# OpenWeatherMap API key — optional, get free tier at openweathermap.org
# App degrades gracefully without it (map overlays disabled)
OWM_API_KEY=your_openweathermap_key_here

# Client (prefix VITE_ so Vite exposes to browser)
VITE_API_URL=http://localhost:5000
